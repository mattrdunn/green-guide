# MongoDB Atlas connection string (Database > Connect > Drivers > Node.js).
# Include the database name in the path — collections are created under it.
# Copy this file to .env.local and fill in real credentials. Never commit .env.local.
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/green-guide?retryWrites=true&w=majority

# Public base URL for plant image assets (Cloudflare R2 bucket behind a custom
# domain). Object keys stored in MongoDB are appended to this, no trailing slash.
NEXT_PUBLIC_IMAGE_BASE_URL=https://images.greenguideapp.com
