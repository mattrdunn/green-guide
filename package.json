        "db:seed:plants": "tsx scripts/seed-plants.ts",
        "db:seed:pests": "tsx scripts/seed-pests.ts",
        "db:seed:genus": "tsx scripts/seed-genus.ts",
        "images:find": "tsx scripts/tools/find-images.ts",
        "images:upload": "tsx scripts/tools/upload-images.ts"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.9.2",
        "clsx": "^2.1.1",
        "framer-motion": "^12.23.24",
        "i18next": "^25.6.1",
        "mongoose": "^9.7.3",
        "next": "^16.0.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-i18next": "^16.2.4",
        "react-redux": "^9.2.0"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "^3.1080.0",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^24",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.7.1",
        "tailwind-merge": "^3.3.1",
        "tailwindcss": "^4",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "allowScripts": {
        "esbuild@0.28.1": true,
        "fsevents@2.3.3": true,
        "sharp@0.34.5": true
